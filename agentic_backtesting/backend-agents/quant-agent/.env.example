# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# AgentCore Configuration
AGENTCORE_REGION=us-east-1
AGENTCORE_ENVIRONMENT=demo

STRATEGY_GENERATOR_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/strategy_generator-xxx
BACKTEST_SUMMARY_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/results_summary-xxx

# MCP Gateway Configuration (for market data access)
AGENTCORE_GATEWAY_URL=https://your-gateway-id.bedrock-agentcore.us-east-1.amazonaws.com

# Cognito Configuration (client_credentials grant for MCP Gateway auth)
COGNITO_DOMAIN=your-cognito-domain-prefix
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=your-cognito-client-secret

# Model Configuration
QUANT_AGENT_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Application Configuration
LOG_LEVEL=INFO
AGENTCORE_DEMO_MODE=true