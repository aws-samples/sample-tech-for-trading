# AWS Bedrock Configuration
# Copy this file to .env and fill in your values

# AWS Region for Bedrock
AWS_REGION=us-east-1

# Strategy Generator Agent Configuration
STRATEGY_GENERATOR_MODEL_ID=us.anthropic.claude-opus-4-6-v1
STRATEGY_GENERATOR_TEMPERATURE=0.3

# Optional: AgentCore Memory for cross-session strategy learning
# (memory disabled if not set)
#STRATEGY_GENERATOR_MEMORY_ID=strategy_generator_mem-xxxxxxxx
